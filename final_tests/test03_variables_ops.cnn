// Test03 variables and ops
int main() {
    int x;
    int y;
    int z;
    x=10;
    y=3;
    if(x>y) {
        z = x + y;
    } else {
        z = x - y;
    }
    printf(z); // esperado:13

    x = x +5;
    printf(x); // esperado:15

    y = y *2;
    printf(y); // esperado:6

    x = x /3;
    printf(x); // esperado:5

    y = y -1;
    printf(y); // esperado:5

    return 0;
}
