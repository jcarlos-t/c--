int main() {
    int a;
    int b;
    int c;
    int d;
    int e;
    int f;
    long long sum;
    sum = 0;
    int i;
    for (i = 0; i < 15000000; i = i + 1) {
        a = 1;
        b = 2;
        c = 3;
        d = 4;
        e = 5;
        f = 6;
        sum = sum + a + b + c + d + e + f + i;
    }
    printf("%ld\n", sum);
    return 0;
}
