// Struct and pointer benchmark - tests struct access and pointer operations
struct Point {
    int x;
    int y;
};

int main() {
    int n;
    n = 100000;
    
    struct Point p;
    p.x = 1;
    p.y = 2;
    
    struct Point* ptr;
    ptr = &p;
    
    int sum;
    sum = 0;
    
    int i;
    i = 0;
    while (i < n) {
        ptr->x = ptr->x + i;
        ptr->y = ptr->y + i * 2;
        sum = sum + ptr->x + ptr->y;
        i = i + 1;
    }
    
    printf(sum);
    return 0;
}
