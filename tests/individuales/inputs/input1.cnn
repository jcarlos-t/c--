// Edge case test: Matrices (multidimensional arrays)
// Tests complex indexing, memory layout, and edge cases

int main() {
    bool ok;
    
    // Test 1: 3D array indexing
    int cube[2][3][4];
    int i, j, k;
    for (i = 0; i < 2; i = i + 1) {
        for (j = 0; j < 3; j = j + 1) {
            for (k = 0; k < 4; k = k + 1) {
                cube[i][j][k] = i * 100 + j * 10 + k;
            }
        }
    }
    ok = cube[1][2][3] == 123;
    printf("%d\n", ok); // esperado: 1
    
    // Test 2: Matrix transposition simulation
    int mat[3][3];
    mat[0][0] = 1; mat[0][1] = 2; mat[0][2] = 3;
    mat[1][0] = 4; mat[1][1] = 5; mat[1][2] = 6;
    mat[2][0] = 7; mat[2][1] = 8; mat[2][2] = 9;
    
    int transposed[3][3];
    for (i = 0; i < 3; i = i + 1) {
        for (j = 0; j < 3; j = j + 1) {
            transposed[j][i] = mat[i][j];
        }
    }
    ok = transposed[0][2] == 7 && transposed[2][0] == 3;
    printf("%d\n", ok); // esperado: 1
    
    // Test 3: Ragged-like behavior with different dimensions
    int ragged[2][4];
    ragged[0][0] = 1; ragged[0][1] = 2; ragged[0][2] = 3; ragged[0][3] = 4;
    ragged[1][0] = 5; ragged[1][1] = 6; ragged[1][2] = 7; ragged[1][3] = 8;
    
    ok = ragged[1][3] == 8;
    printf("%d\n", ok); // esperado: 1
    
    // Test 4: Matrix multiplication (2x2)
    int a[2][2];
    int b[2][2];
    int c[2][2];
    
    a[0][0] = 1; a[0][1] = 2;
    a[1][0] = 3; a[1][1] = 4;
    
    b[0][0] = 5; b[0][1] = 6;
    b[1][0] = 7; b[1][1] = 8;
    
    c[0][0] = a[0][0] * b[0][0] + a[0][1] * b[1][0];
    c[0][1] = a[0][0] * b[0][1] + a[0][1] * b[1][1];
    c[1][0] = a[1][0] * b[0][0] + a[1][1] * b[1][0];
    c[1][1] = a[1][0] * b[0][1] + a[1][1] * b[1][1];
    
    ok = c[0][0] == 19 && c[1][1] == 50;
    printf("%d\n", ok); // esperado: 1
    
    // Test 5: Array of arrays with char
    char grid[3][3];
    grid[0][0] = 'A'; grid[0][1] = 'B'; grid[0][2] = 'C';
    grid[1][0] = 'D'; grid[1][1] = 'E'; grid[1][2] = 'F';
    grid[2][0] = 'G'; grid[2][1] = 'H'; grid[2][2] = 'I';
    
    ok = grid[1][1] == 'E';
    printf("%d\n", ok); // esperado: 1
    
    // Test 6: Float matrix
    float fmat[2][3];
    fmat[0][0] = 1.5; fmat[0][1] = 2.5; fmat[0][2] = 3.5;
    fmat[1][0] = 4.5; fmat[1][1] = 5.5; fmat[1][2] = 6.5;
    
    float fsum = fmat[0][0] + fmat[1][2];
    ok = fsum > 7.9 && fsum < 8.1;
    printf("%d\n", ok); // esperado: 1
    
    // Test 7: Large matrix initialization
    int large[10][10];
    for (i = 0; i < 10; i = i + 1) {
        for (j = 0; j < 10; j = j + 1) {
            large[i][j] = i * 10 + j;
        }
    }
    ok = large[9][9] == 99;
    printf("%d\n", ok); // esperado: 1
    
    // Test 8: Diagonal access
    int diag[5][5];
    for (i = 0; i < 5; i = i + 1) {
        for (j = 0; j < 5; j = j + 1) {
            diag[i][j] = 0;
        }
        diag[i][i] = 1;
    }
    
    int diag_sum = 0;
    for (i = 0; i < 5; i = i + 1) {
        diag_sum = diag_sum + diag[i][i];
    }
    ok = diag_sum == 5;
    printf("%d\n", ok); // esperado: 1
    
    // Test 9: Matrix row sum
    int matrix[3][4];
    matrix[0][0] = 1; matrix[0][1] = 2; matrix[0][2] = 3; matrix[0][3] = 4;
    matrix[1][0] = 5; matrix[1][1] = 6; matrix[1][2] = 7; matrix[1][3] = 8;
    matrix[2][0] = 9; matrix[2][1] = 10; matrix[2][2] = 11; matrix[2][3] = 12;
    
    int row_sum = 0;
    for (j = 0; j < 4; j = j + 1) {
        row_sum = row_sum + matrix[1][j];
    }
    ok = row_sum == 26;
    printf("%d\n", ok); // esperado: 1
    
    // Test 10: Matrix column sum
    int col_sum = 0;
    for (i = 0; i < 3; i = i + 1) {
        col_sum = col_sum + matrix[i][2];
    }
    ok = col_sum == 21;
    printf("%d\n", ok); // esperado: 1
    
    return 0;
}
