int main() {
    int matriz[2][3];
    int i;
    int j;

    // Inicialización manual celda por celda
    matriz[0][0] = 1;
    matriz[0][1] = 2;
    matriz[0][2] = 3;
    matriz[1][0] = 4;
    matriz[1][1] = 5;
    matriz[1][2] = 6;

    // Recorrido con bucles for permitidos
    for (i = 0; i < 2; i = i + 1) {
        for (j = 0; j < 3; j = j + 1) {
            printf(matriz[i][j]); 
            // Esperado secuencial: 1, 2, 3, 4, 5, 6
        }
    }

    return 0;
}