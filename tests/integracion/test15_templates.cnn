struct Pair {
    int first;
    int second;
};

int add_ints(int a, int b) {
    return a + b;
}

int main() {
    int s;
    s = add_ints(10, 20);
    printf(s); // esperado: 30

    struct Pair p;
    p.first = 5;
    p.second = 15;
    int sum;
    sum = p.first + p.second;
    printf(sum); // esperado: 20

    return 0;
}
