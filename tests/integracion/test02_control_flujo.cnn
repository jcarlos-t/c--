// Test 02: Estructuras de control
int main() {
    int i;
    int sum;
    i =0;
    sum=0;
    do {
        sum = sum +i;
        i = i +1;
    } while(i <=5);

    for(i=6; i<=10; i=i+1){
        if(i>8) {
            break;
        }
        if(i ==7){
            continue;
        }
        sum = sum +i;
    }
    printf(sum); // esperado:29
    return 0;
}
