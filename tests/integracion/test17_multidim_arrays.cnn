// Test 17: Arreglos multidimensionales
int main() {
    int m[2][3];
    m[0][0] = 1;
    m[0][1] = 2;
    m[0][2] = 3;
    m[1][0] = 4;
    m[1][1] = 5;
    m[1][2] = 6;

    int sum;
    sum = m[0][0] + m[1][2];
    printf("%d\n", sum); // esperado: 7

    sum = m[0][1] + m[1][1];
    printf("%d\n", sum); // esperado: 7

    return 0;
}
