// Test10 Complex Expressions
int main() {
    int result;
    int a;
    int b;
    a=7;
    b=3;
    result = (a + b) * (a - b);
    printf("%d\n", result); // esperado:40
    a = a + b;
    printf("%d\n", a); // esperado:10
    printf("%d\n", b); // esperado:3
    if((a != b) && (b>0)) {
        printf("%d\n", 1); // esperado:1
    } else {
        printf("%d\n", 0);
    }
    return 0;
}
