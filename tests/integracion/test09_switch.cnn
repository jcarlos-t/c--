int main() {
    int x;
    x = 2;
    switch (x) {
        case 1: {
            printf("%d\n", 10);
        }
        case 2: {
            printf("%d\n", 20); // esperado: 20
        }
        case 3: {
            printf("%d\n", 30); // esperado: 30
        }
        default: {
            printf("%d\n", 99); // esperado: 99
        }
    }
    return 0;
}
