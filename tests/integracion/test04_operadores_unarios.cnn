// Test04: Unary ops
int main() {
    int a;
    int b;
    int c;
    a = 0;
    b = 5;
    c = 0;

    a = ++b;
    printf("%d\n", a); // esperado:6
    printf("%d\n", b); // esperado:6

    c = b--;
    printf("%d\n", c); // esperado:6
    printf("%d\n", b); // esperado:5

    if(!(a==0) && (b < 10 || c>0 )){
        printf("%d\n", 1); // esperado:1
    } else {
        printf("%d\n", 0);
    }

    return 0;
}
