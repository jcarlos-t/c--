struct Data {
    int a;
    double b;
    char c;
};

int main() {
    int sizeChar;
    int sizeInt;
    int sizeFloat;
    int sizeDouble;
    int sizeStruct;

    sizeChar = sizeof(char);
    sizeInt = sizeof(int);
    sizeFloat = sizeof(float);
    sizeDouble = sizeof(double);
    sizeStruct = sizeof(struct Data);

    printf(sizeChar);   // esperado: 1
    printf(sizeInt);    // esperado: 4
    printf(sizeFloat);  // esperado: 4
    printf(sizeDouble); // esperado: 8
    printf(sizeStruct); // esperado: 24

    return 0;
}
