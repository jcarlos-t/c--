// Test 20: Aritmética con float y double
int main() {
    float a;
    float b;
    float result;
    bool ok;

    a = 2.5;
    b = 1.5;
    result = a + b;
    ok = result == 4.0;
    printf("%d\n", ok); // esperado: 1

    result = a * b;
    ok = result > 3.0;
    printf("%d\n", ok); // esperado: 1

    double x;
    double y;
    double z;
    x = 10.0;
    y = 3.0;
    z = x / y;
    ok = z > 3.0;
    printf("%d\n", ok); // esperado: 1

    return 0;
}
