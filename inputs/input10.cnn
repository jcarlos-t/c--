int fib(int n) {
    int a;
    int b;
    int tmp;
    if (n <= 1) {
        return n;
    }
    a = 0;
    b = 1;
    while (n > 1) {
        tmp = a + b;
        a = b;
        b = tmp;
        n = n - 1;
    }
    return b;
}

int main() {
    int val;
    val = fib(10);
    print(val);
    return 0;
}
