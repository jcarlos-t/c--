int main() {
    int result;
    int a;
    int b;
    a = 7;
    b = 3;

    result = (a + b) * (a - b);
    print(result);

    a += b;
    print(a);

    result = (a > b) ? a : b;
    print(result);

    if ((a != b) && (b > 0)) {
        print(1);
    } else {
        print(0);
    }

    return 0;
}
