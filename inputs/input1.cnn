int triple(int x) {
    return 3 * x;
}

int factorial(int x) {
    if (x == 0) { return 1; }
    return factorial(x - 1) * x;
}

int suma(int a, int b) {
    return a + b;
}

int main() {
    int a = 2 * 2;
    printf(a);
    printf(factorial(a));
    printf(triple(a));
    printf(suma(a, a));
    return 0;
}
